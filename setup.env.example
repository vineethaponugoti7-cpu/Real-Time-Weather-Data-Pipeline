# Copy this file to setup.env and fill in your real values.
# setup.env is gitignored and must NEVER be committed.

# Get a free API key at https://openweathermap.org/api
OWM_API_KEY=your_openweathermap_api_key_here

# AWS settings (only needed for the cloud version)
AWS_REGION=us-east-1
KINESIS_STREAM=weather-stream

# Optional
POLL_INTERVAL_SEC=10
OUTPUT_DIR=data
